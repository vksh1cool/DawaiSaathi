{
  "$schema": "./node_modules/wrangler/config-schema.json",
  "name": "dawaisaathi",
  "main": ".open-next/worker.js",
  "compatibility_date": "2026-07-16",
  "compatibility_flags": ["nodejs_compat"],

  // OpenNext writes these static assets during `npm run cf:build`.
  "assets": {
    "directory": ".open-next/assets",
    "binding": "ASSETS"
  },

  // OpenNext's static/ISR cache is isolated from patient photos and audio.
  // `WORKER_SELF_REFERENCE` is required for cache revalidation callbacks.
  "services": [
    {
      "binding": "WORKER_SELF_REFERENCE",
      "service": "dawaisaathi"
    }
  ],

  // Replace `database_id` after running `wrangler d1 create dawaisaathi`.
  // The R2 bucket stays private: all media is served through authenticated
  // application routes rather than a public bucket domain.
  "d1_databases": [
    {
      "binding": "DAWAISAATHI_DB",
      "database_name": "dawaisaathi",
      "database_id": "5b169b9a-5a27-41cd-866b-587665e80a42",
      "migrations_dir": "migrations/d1"
    }
  ],
  "r2_buckets": [
    {
      "binding": "DAWAISAATHI_ASSETS",
      "bucket_name": "dawaisaathi-private-assets"
    },
    {
      "binding": "NEXT_INC_CACHE_R2_BUCKET",
      "bucket_name": "dawaisaathi-next-cache"
    }
  ],

  // Transactional product feedback only. Before deployment, onboard
  // launchpixel.in in Cloudflare Email Sending so feedback@launchpixel.in is
  // a verified sender. The browser never receives email credentials.
  "send_email": [
    {
      "name": "EMAIL",
      "allowed_sender_addresses": ["feedback@launchpixel.in"]
    }
  ],

  // This Durable Object is owned by OpenNext and queues/de-duplicates ISR
  // revalidation. It contains cache coordination data, not health records.
  "durable_objects": {
    "bindings": [
      {
        "name": "NEXT_CACHE_DO_QUEUE",
        "class_name": "DOQueueHandler"
      }
    ]
  },
  "migrations": [
    {
      "tag": "v1",
      "new_sqlite_classes": ["DOQueueHandler"]
    }
  ],

  "vars": {
    "AI_PROVIDER": "groq",
    "GROQ_MODEL": "llama-3.3-70b-versatile",
    "GROQ_VISION_MODEL": "meta-llama/llama-4-scout-17b-16e-instruct",
    "DATABASE_DRIVER": "d1",
    "STORAGE_DRIVER": "r2",
    // The Pages gateway is the only user-facing origin. Keeping this stable is
    // essential for Twilio signature validation and callback URLs.
    "PUBLIC_BASE_URL": "https://dawaisaathi.pages.dev",
    "NEXT_INC_CACHE_R2_PREFIX": "next-incremental-cache",
    "REQUIRE_ACCESS_GATE": "false",
    "DEFAULT_TZ": "Asia/Kolkata",
    "DEMO_MODE": "false",
    "WORKER_TICK_SECONDS": "60",
    "RETRY_DELAY_MINUTES": "10",
    "MAX_CALL_ATTEMPTS": "3",
    "OPENAI_DAILY_LLM_REQUEST_LIMIT": "50",
    "OPENAI_DAILY_TTS_GENERATION_LIMIT": "12",
    // SHA-256 of the certificate the installed APK is signed with. Cert
    // fingerprints are public by design (Android publishes them in
    // assetlinks.json); swap for the release-key fingerprint at launch.
    "ANDROID_APP_CERT_SHA256": "B7:18:EB:9F:9C:7C:AF:AA:13:25:F2:95:04:8C:CD:69:A9:24:95:8B:91:B4:80:01:E3:5E:D2:63:90:7A:84:AD"
  },

  "observability": {
    "enabled": true,
    "logs": { "enabled": true, "head_sampling_rate": 1 },
    "traces": { "enabled": true, "head_sampling_rate": 0.1 }
  }
}
