# ── AI provider ──────────────────────────────────────────────────────
# Keep real keys in an untracked .env file. Never commit credentials here.
# Supported providers: openai | nim | groq
AI_PROVIDER=groq
OPENAI_API_KEY=replace-with-your-openai-key
OPENAI_MODEL=gpt-5.6
NIM_API_KEY=replace-with-your-nim-key
NIM_BASE_URL=https://integrate.api.nvidia.com/v1
NIM_MODEL=
GROQ_API_KEY=replace-with-your-groq-key
GROQ_MODEL=llama-3.3-70b-versatile
GROQ_VISION_MODEL=meta-llama/llama-4-scout-17b-16e-instruct

# ── Gemini — primary voice + safety dual-verify ──────────────────────
# One key powers two things:
#  1. The PRIMARY voice for reminder calls and the in-app preview. Gemini native
#     TTS is genuinely human and speaks Hindi + English from a single voice,
#     free on the Gemini free tier.
#  2. A dual-verify cross-check on the two safety-critical calls (drug-interaction
#     findings + medicine-strip extraction), alongside AI_PROVIDER above.
# Leave blank to keep single-provider behaviour AND fall back to the device's
# built-in voice for previews/calls.
# IMPORTANT: the key's Google project must have access to the TTS preview models.
# A fresh key from Google AI Studio normally does; if the project is denied
# access (HTTP 403), the app degrades to the on-device browser voice.
GEMINI_API_KEY=replace-with-your-gemini-key
GEMINI_MODEL=gemini-2.0-flash
# Voice model + voices. gemini-2.5-flash-preview-tts is proven on the free tier.
# For even more expressive delivery try gemini-3.1-flash-tts-preview if your
# project has access. Voices are Gemini prebuilt names — Sulafat ("Warm") and
# Algieba ("Smooth") are chosen for elderly-friendly warmth and clarity.
GEMINI_TTS_MODEL=gemini-2.5-flash-preview-tts
GEMINI_TTS_VOICE_FEMALE=Sulafat
GEMINI_TTS_VOICE_MALE=Algieba
# Separate, smaller daily cap for dual-verify (does not affect free TTS).
GEMINI_DAILY_LLM_REQUEST_LIMIT=6

# ── OpenAI text-to-speech (optional paid last resort behind Gemini) ──
OPENAI_TTS_MODEL=gpt-4o-mini-tts
OPENAI_TTS_VOICE_FEMALE=coral
OPENAI_TTS_VOICE_MALE=onyx
# Hard local per-day cap on outbound API attempts. Cached audio costs no slot.
# Set either value to 0 to block that class of OpenAI request completely.
OPENAI_DAILY_LLM_REQUEST_LIMIT=50
OPENAI_DAILY_TTS_GENERATION_LIMIT=12

# ── Twilio (required only for real calls or explicitly consented SMS) ────────
TWILIO_ACCOUNT_SID=replace-with-your-account-sid
TWILIO_AUTH_TOKEN=replace-with-your-auth-token
TWILIO_FROM_NUMBER=+1XXXXXXXXXX
# Preferred for SMS: create a Messaging Service in Twilio and configure its
# inbound webhook as /api/twilio/sms/inbound after deployment. Leave blank to
# use an SMS-capable From number for a small verified cohort.
TWILIO_MESSAGING_SERVICE_SID=
# ngrok https URL (no trailing slash) — used for Twilio webhooks + audio <Play>
PUBLIC_BASE_URL=

# ── Database ─────────────────────────────────────────────────────────
# Standalone Prisma scripts use this local SQLite file. `next dev` loads the
# local D1 binding from wrangler.jsonc; run `npm run d1:migrate:local` first.
DATABASE_URL=file:./dev.db

# ── Supabase rollout (leave AUTH_DRIVER=access_gate until the tenant/RLS
# migration has been applied and exercised with synthetic data) ─────────
AUTH_DRIVER=access_gate
SUPABASE_URL=
# Supabase's anon/publishable key is safe for browser use, but keep it in
# local/Worker configuration rather than source control.
SUPABASE_ANON_KEY=
# Server-only. Never expose through a NEXT_PUBLIC_* variable.
SUPABASE_SERVICE_ROLE_KEY=
# Keep false until the schema/RLS verification and every health-data API route
# has moved from the isolated D1 demo to the Supabase tenant adapter.
SUPABASE_TENANT_RUNTIME_READY=false
# Google sign-in and the "Try the demo" button additionally require two
# dashboard-only steps in the Supabase project (no env var here):
#   1. Auth > Providers > Google — configure a Google Cloud OAuth client.
#   2. Auth > Settings — enable "Allow anonymous sign-ins".

# ── openFDA (optional; raises daily quota) ───────────────────────────
OPENFDA_API_KEY=

# ── App behavior ─────────────────────────────────────────────────────
DEFAULT_TZ=Asia/Kolkata
DEMO_MODE=true
WORKER_TICK_SECONDS=60
RETRY_DELAY_MINUTES=10
MAX_CALL_ATTEMPTS=3

# ── Android TWA (set to the SHA-256 fingerprint of the release signing key) ─
ANDROID_APP_CERT_SHA256=

# ── Demo ─────────────────────────────────────────────────────────────
# Presenter's Twilio-verified phone that plays Kamla Devi's reminder calls.
DEMO_PATIENT_PHONE=+91XXXXXXXXXX
