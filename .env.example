# ── OpenAI (required) ────────────────────────────────────────────────
OPENAI_API_KEY=sk-...
OPENAI_MODEL=gpt-5.6
OPENAI_TTS_MODEL=gpt-4o-mini-tts
OPENAI_TTS_VOICE_FEMALE=coral
OPENAI_TTS_VOICE_MALE=onyx

# ── Twilio (required only for real phone calls; simulated calls work without) ─
TWILIO_ACCOUNT_SID=
TWILIO_AUTH_TOKEN=
TWILIO_FROM_NUMBER=
# ngrok https URL (no trailing slash) — used for Twilio webhooks + audio <Play>
PUBLIC_BASE_URL=

# ── Database ─────────────────────────────────────────────────────────
DATABASE_URL=file:./dev.db

# ── openFDA (optional; raises daily quota) ───────────────────────────
OPENFDA_API_KEY=

# ── App behavior ─────────────────────────────────────────────────────
DEFAULT_TZ=Asia/Kolkata
DEMO_MODE=true
WORKER_TICK_SECONDS=60
RETRY_DELAY_MINUTES=10
MAX_CALL_ATTEMPTS=3

# ── Demo ─────────────────────────────────────────────────────────────
# Presenter's Twilio-verified phone that plays Kamla Devi's reminder calls.
DEMO_PATIENT_PHONE=+91XXXXXXXXXX
